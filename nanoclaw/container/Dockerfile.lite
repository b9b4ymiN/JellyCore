# NanoClaw Agent Container (Lite Variant)
# Text/code-focused runtime without Chromium/Playwright stack.

FROM node:22-slim AS builder

WORKDIR /app
COPY agent-runner/package*.json ./
RUN npm install
COPY agent-runner/ ./
RUN npm run build

FROM node:22-slim
ARG BUILD_DATE=unknown
ARG VCS_REF=unknown
LABEL org.opencontainers.image.title="nanoclaw-agent-lite" \
      org.opencontainers.image.created=$BUILD_DATE \
      org.opencontainers.image.revision=$VCS_REF

# Keep runtime dependencies minimal in lite image.
RUN apt-get update -o Acquire::Retries=3 && apt-get install -y --no-install-recommends \
    curl \
    docker.io \
    git \
    python3 \
    python3-pip \
    python3-venv \
    && rm -rf /var/lib/apt/lists/*

RUN pip3 install --no-cache-dir --break-system-packages \
    requests \
    beautifulsoup4 \
    lxml

# No browser tooling in lite image.
ENV PLAYWRIGHT_SKIP_BROWSER_DOWNLOAD=1

# Install core agent CLIs.
RUN npm install -g @anthropic-ai/claude-code @openai/codex pm2

# External MCP servers - same behavior as full image.
RUN git clone --depth=1 https://github.com/elizabethtrykin/oura-mcp /opt/oura-mcp \
    && cd /opt/oura-mcp \
    && npm install \
    && npm run build \
    && rm -rf /opt/oura-mcp/.git

RUN git clone --depth=1 https://github.com/Alex2Yang97/yahoo-finance-mcp /opt/yahoo-finance-mcp \
    && pip3 install --no-cache-dir --break-system-packages \
      "mcp[cli]>=1.6.0" \
      "yfinance>=0.2.62" \
      "pandas>=2.0.0" \
    && rm -rf /opt/yahoo-finance-mcp/.git

RUN npm install -g notebooklm-mcp@latest

RUN npm install -g @a-bonus/google-docs-mcp@latest \
    && mkdir -p /opt/google-docs-mcp \
    && cat > /opt/google-docs-mcp/start.sh <<'EOF' \
    && chmod +x /opt/google-docs-mcp/start.sh
#!/bin/sh
set -e

export XDG_CONFIG_HOME="${XDG_CONFIG_HOME:-/home/node/.claude/config}"
mkdir -p "${XDG_CONFIG_HOME}/google-docs-mcp"
exec google-docs-mcp "$@"
EOF

RUN pm2 install pm2-logrotate && \
    pm2 set pm2-logrotate:max_size 50M && \
    pm2 set pm2-logrotate:retain 7 && \
    pm2 set pm2-logrotate:compress true

WORKDIR /app
COPY --from=builder /app/dist ./dist
COPY --from=builder /app/node_modules ./node_modules
COPY --from=builder /app/package.json ./
COPY config/ /app/config/

RUN mkdir -p /workspace/group /workspace/global /workspace/extra /workspace/ipc/messages /workspace/ipc/tasks /workspace/ipc/input

RUN cat > /app/entrypoint.sh <<'EOF' \
 && chmod +x /app/entrypoint.sh
#!/bin/bash
set -e

mkdir -p /workspace/ipc/input /workspace/ipc/messages /workspace/ipc/tasks 2>/dev/null || true
chmod -R 777 /workspace/ipc 2>/dev/null || true
chown -R node:node /workspace/group /workspace/global /workspace/extra /home/node 2>/dev/null || true

if [ -S /var/run/docker.sock ]; then
  SOCK_GID="$(stat -c '%g' /var/run/docker.sock 2>/dev/null || true)"
  if [ -n "$SOCK_GID" ]; then
    SOCK_GROUP="$(getent group "$SOCK_GID" | cut -d: -f1 || true)"
    if [ -z "$SOCK_GROUP" ]; then
      SOCK_GROUP="dockersock"
      groupadd -g "$SOCK_GID" "$SOCK_GROUP" 2>/dev/null || true
    fi
    usermod -aG "$SOCK_GROUP" node 2>/dev/null || true
  fi
fi

cat > /tmp/input.json
chmod 644 /tmp/input.json
exec su -s /bin/bash node -c "node /app/dist/index.js < /tmp/input.json"
EOF

RUN chown -R node:node /workspace /home/node
WORKDIR /workspace/group
ENTRYPOINT ["/app/entrypoint.sh"]
