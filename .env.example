# JellyCore Environment Variables
# Copy this file to .env and fill in the values

# --- Required ---

# WhatsApp auth encryption passphrase (min 16 characters)
JELLYCORE_AUTH_PASSPHRASE=

# Anthropic API key or Claude Code OAuth token
ANTHROPIC_API_KEY=
# CLAUDE_CODE_OAUTH_TOKEN=

# Custom API base URL (for third-party proxies like Z.AI)
# ANTHROPIC_BASE_URL=

# --- Required for Docker services ---

# ChromaDB authentication token (set this manually)
CHROMA_AUTH_TOKEN=

# Oracle auth token used by protected Oracle API routes
ORACLE_AUTH_TOKEN=

# IPC integrity signing secret (auto-generated by NanoClaw if empty)
# JELLYCORE_IPC_SECRET=

# --- Optional ---

# Oracle API URL (for MCP-HTTP bridge in containers)
# ORACLE_API_URL=http://host.containers.internal:47778
# Thai NLP sidecar URL (optional; Oracle falls back gracefully when unavailable)
# THAI_NLP_URL=http://thai-nlp:8000

# Disable external MCP servers by name (comma-separated, e.g. "oura,yfinance")
# NANOCLAW_EXTERNAL_MCP_DISABLED=

# Oura Ring MCP personal access token (optional)
# OURA_PERSONAL_ACCESS_TOKEN=

# Google Docs MCP OAuth credentials (optional)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# Optional profile namespace for token storage (e.g. work, personal)
# GOOGLE_MCP_PROFILE=
# Optional path override; default used by image wrapper: /home/node/.claude/config
# GOOGLE_DOCS_XDG_CONFIG_HOME=/home/node/.claude/config
# Optional shared token bootstrap directory (place token.json here)
# - no profile: data/google-docs-auth/token.json
# - with GOOGLE_MCP_PROFILE=main: data/google-docs-auth/main/token.json
# GOOGLE_DOCS_AUTH_PATH=data/google-docs-auth

# Container image name
# CONTAINER_IMAGE=nanoclaw-agent:latest
# Optional auto-build Dockerfile override (default: Dockerfile, or Dockerfile.lite when image name includes "lite")
# AGENT_DOCKERFILE=Dockerfile

# Agent runtime flags
# AGENT_CODEX_ENABLED=false
# AGENT_SWARM_ENABLED=false
# AGENT_MODE_GLOBAL_DEFAULT=off
# LLM provider for agent-runner when runtime=fon: claude (default), openai, ollama
# LLM_PROVIDER=claude
# OpenAI-compatible provider settings (required when LLM_PROVIDER=openai)
# OPENAI_BASE_URL=https://api.openai.com
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4.1
# Ollama provider settings (required when LLM_PROVIDER=ollama)
# OLLAMA_BASE_URL=http://host.containers.internal:11434
# OLLAMA_MODEL=llama3.1

# Codex runtime auth contract (required for mode=swarm|codex)
# 1) User must provide ChatGPT login file at: data/codex-auth/auth.json
# 2) No API-key fallback is used in Codex path
# CODEX_AUTH_REQUIRED=true
# CODEX_AUTH_PATH=data/codex-auth
# CODEX_MODEL=gpt-5.3-codex
# CODEX_EXEC_TIMEOUT_MS=600000

# Dangerous: give agent containers broad file + docker-socket access for self-healing
# AGENT_FULL_ACCESS=false

# Oracle CORS allowlist for browser origins (comma-separated)
# ORACLE_ALLOWED_ORIGINS=http://localhost:47778,http://127.0.0.1:47778

# Oracle rate limiter settings
# ORACLE_RATE_LIMIT_WINDOW_MS=60000
# ORACLE_RATE_LIMIT_READ_LIMIT=60
# ORACLE_RATE_LIMIT_WRITE_LIMIT=30

# Optional host port overrides (avoids port collisions on local machines)
# ORACLE_HOST_PORT=47778
# NANOCLAW_HOST_PORT=47779
# PROMETHEUS_HOST_PORT=9090
# GRAFANA_HOST_PORT=3000
# ALERTMANAGER_HOST_PORT=9093
# LOKI_HOST_PORT=3100

# Alertmanager -> Telegram notifications
# ALERT_TELEGRAM_BOT_TOKEN=
# ALERT_TELEGRAM_CHAT_ID=

# Grafana local admin bootstrap
# GRAFANA_ADMIN_USER=admin
# GRAFANA_ADMIN_PASSWORD=admin

# Backup/restore automation
# BACKUP_DIR=./backups
# BACKUP_RETENTION_DAYS=14
# RCLONE_REMOTE=

# Container timeout (ms, default: 1800000 = 30min)
# CONTAINER_TIMEOUT=1800000

# Max concurrent containers (default: 5)
# MAX_CONCURRENT_CONTAINERS=5

# Timezone for scheduled tasks
# TZ=Asia/Bangkok

# Assistant name (default: Fon)
# ASSISTANT_NAME=Fon
